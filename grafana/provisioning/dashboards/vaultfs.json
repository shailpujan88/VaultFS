      "id": 2,
      "title": "Request latency (p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vaultfs_request_duration_seconds_bucket[1m])) by (le, method))",
          "legendFormat": "{{method}}"
        }
      ]
